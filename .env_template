# Docker Compose profile that selects which services to start.
# Supported values:
#   standard - runs the full stack: kit + aeronim (live inference) + web frontend.
#              Requires two GPUs (one for rendering, one for inference) and an NGC
#              API key to pull the AeroNIM container image.
#   lite     - runs kit-lite + web frontend without aeronim. Inference results
#              are loaded from pre-baked data under data/cache/ instead of being
#              computed on the fly. Useful for single-GPU machines or when an
#              NGC key is unavailable.
# Multiple profiles can be combined with a comma (e.g. COMPOSE_PROFILES=standard,lite),
# or overridden at the CLI with `docker compose --profile <name> up`.
COMPOSE_PROFILES=standard

# NVIDIA GPU Cloud (NGC) API key.
# Required to pull the AeroNIM container image from NGC.
# Obtain from https://org.ngc.nvidia.com/setup/api-key and set it in your shell
# before running docker compose (e.g. export NGC_API_KEY=...).
NGC_API_KEY=${NGC_API_KEY}

# Hostname or IP of the Triton Inference Server used by the Kit app for CFD inference.
# In the default Docker Compose setup this points to the 'aeronim' service by name.
# Change this if you are running Triton on a separate host or a remote machine.
NIM_TRITON_IP_ADDRESS=aeronim

# HTTP port that the Triton Inference Server listens on.
# Change this only if you have reconfigured Triton to use a non-default port.
NIM_TRITON_HTTP_PORT=8080

# Host port mapped to the web frontend container.
# The trame app always listens on port 5173 inside the container — this value
# only controls which port is exposed on the host. Change it if port 5173 is
# already in use on your machine (e.g. set to 9090 to access via localhost:9090).
WEB_HOST_PORT=5173 # 80

# Host ports mapped to the launch proxy. The proxy serves the Trame app
# and forwards Kit's /sign_in endpoint, which is useful for HTTPS launchable
# links such as Brev. The WebRTC media ports below still need to be reachable
# directly from the browser.
RTWT_HTTP_HOST_PORT=80
RTWT_HTTPS_HOST_PORT=443

# Optional browser streaming overrides. Leave these empty for local/direct
# Docker Compose use. When the UI is opened through HTTPS, the client
# automatically uses the page host on 443 for signaling and uses the discovered
# public IP for WebRTC media when available.
RTWT_SIGNALING_SERVER=
RTWT_SIGNALING_PORT=
RTWT_MEDIA_SERVER=
RTWT_FORCE_WSS=
RTWT_PUBLIC_IP=
RTWT_DISCOVER_PUBLIC_IP=1

# CUDA device index for the Kit WebRTC application.
# Use nvidia-smi to list available GPUs and their indices.
# Change this if your rendering GPU is not device 0.
CUDA_DEVICE_KIT=0

# CUDA device index for the AeroNIM inference container.
# Only used by the `standard` profile (the `lite` profile does not run aeronim).
# Should be a different GPU from CUDA_DEVICE_KIT when multiple GPUs are available,
# as inference and rendering have separate VRAM requirements.
CUDA_DEVICE_AERONIM=1
