# Apply ignores at repo-root build context

# Exclude underscore-prefixed items
**/_build
**/_repo
**/_compiler
**/logs

# Exclude Python cache files
**/__pycache__
trame-app/.venv/
trame-app/static/kit-streamer.iife.js
kit-streamer/node_modules/

# Exclude Dockerfile so changes to it don't invalidate the build cache
Dockerfile

# Exclude components that we don't need when building
# the container images
.git

# data/ and stages/ are bind-mounted by docker compose and provided to the
# Kubernetes deployment by the separate data-image build (see Dockerfile.data
# and Dockerfile.data.dockerignore). Keep them out of the kit image build
# context here so `docker build .` produces a lean kit image.
data
stages
