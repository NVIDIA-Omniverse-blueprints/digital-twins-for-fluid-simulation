mdl 1.6;

using m_mdl = "mdl";

import ::state::normal;
import ..::Templates::OmniGlass::*;
import ::base::mono_mode;
import ::tex::gamma_mode;

export material Glass_Reflectors_Base_Red(*)
 = Templates::OmniGlass::OmniGlass(
    absorption_coeff: color(0.f, 0.f, 0.f),
    use_glass_color_texture: false,
    glass_color: color(1.f, 0.198019803f, 0.f),
    glass_color_texture: texture_2d(),
    frosting_roughness: 0.00999999978f,
    glass_ior: 2.28999996f,
    thin_walled: true,
    depth: 0.00100000005f,
    roughness_texture_influence: 0.f,
    roughness_texture: texture_2d("../../Surfacing/ov_misc_textures_noise/dust1.jpg", ::tex::gamma_linear),
    reflection_color_texture: texture_2d(),
    reflection_color: color(0.495049477f, 0.289187312f, 0.289187312f),
    normal_map_texture: texture_2d(),
    normal_map_strength: 1.f,
    flip_tangent_u: false,
    flip_tangent_v: true,
    enable_opacity: false,
    cutout_opacity: 1.f,
    cutout_opacity_texture: texture_2d(),
    cutout_opacity_mono_source: base::mono_alpha,
    opacity_threshold: 0.f,
    project_uvw: true,
    world_or_object: true,
    uv_space_index: 0,
    texture_translate: float2(0.f),
    texture_rotate: 0.f,
    texture_scale: float2(0.0299999993f));