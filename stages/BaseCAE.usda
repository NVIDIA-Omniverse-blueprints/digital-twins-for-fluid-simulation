                    float3 xformOp:scale = (11.88, 0.25199997, 2.7719998)
                    double3 xformOp:translate = (3.600000023841858, -1.5659999296069145, 0.8999999314546585)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]

                    def FlowEmitterBox "EmitterBox"
                    {
