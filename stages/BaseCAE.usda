                }

                def Cube "Boundary_NegZ"
                {
                    double size = 1
                    float3 xformOp:scale = (11.88, 3.168, 0.25199997)
                    double3 xformOp:translate = (3.600000023841858, 0, -0.48599997609853746)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:scale"]

                    def FlowEmitterBox "EmitterBox"
                    {
                        float allocationScale = 0
                        bool applyPostPressure = 1
                        float burn = 0
                        float coupleRateBurn = 1200
                        float coupleRateDivergence = 1200
                        float coupleRateFuel = 1200
                        float coupleRateSmoke = 1200
