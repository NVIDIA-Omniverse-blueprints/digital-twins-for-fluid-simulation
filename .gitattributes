# Normalize text files on commit to LF endings by default
* text=auto
# Make sure Windows batch files preserve CR/LF line endings, otherwise they may not be able to execute.  Windows
# batch files require a CR/LF for labels to work properly, otherwise they may fail when labels straddle 512-byte
# block boundaries.  This is important when files are downloaded through a zip archive that was authored on a
# Linux machine (the default behavior on GitHub)
*.bat text eol=crlf
*.cmd text eol=crlf
# Make sure shell scripts have LF line endings, even when checked out on a Windows client with autocrlf=true
*.sh text eol=lf

# All files under data go into Git LFS
data/** filter=lfs diff=lfs merge=lfs -text

# ...except the small JSON sidecars alongside the .npz cache entries,
# which stay in regular git so they are diffable.
data/cache/*.json !filter !diff !merge text

# explicitly list extensions to add to LFS
*.png filter=lfs diff=lfs merge=lfs -text
*.exr filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.usd filter=lfs diff=lfs merge=lfs -text
*.stl filter=lfs diff=lfs merge=lfs -text
*.ply filter=lfs diff=lfs merge=lfs -text